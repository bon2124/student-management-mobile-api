<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F7F9FC">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1976D2"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/btnCancel"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentLeft="true"
            android:layout_centerInParent="true"
            android:src="@android:drawable/ic_menu_revert"
            android:contentDescription="Hủy"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Thêm sinh viên"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnSave"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentRight="true"
            android:layout_centerInParent="true"
            android:src="@android:drawable/ic_menu_save"
            android:contentDescription="Lưu"
            app:tint="#FFFFFF" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Mã sinh viên -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mã sinh viên (ID)"
                android:textColor="#1A237E"
                android:textSize="14sp"
                android:textStyle="bold"
                android:drawableLeft="@drawable/ic_badge"
                android:drawablePadding="10dp"
                android:gravity="center_vertical" />
            <EditText
                android:id="@+id/etStudentId"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input_rect"
                android:hint="Nhập mã sinh viên"
                android:inputType="text"
                android:paddingHorizontal="12dp"
                android:textColor="#1E293B"
                android:textColorHint="#94A3B8"
                android:textSize="14sp" />

            <!-- Họ và tên -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Họ và tên"
                android:textColor="#1A237E"
                android:textSize="14sp"
                android:textStyle="bold"
                android:drawableLeft="@drawable/ic_person"
                android:drawablePadding="10dp"
                android:gravity="center_vertical" />
            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input_rect"
                android:hint="Nhập họ và tên"
                android:inputType="textPersonName"
                android:paddingHorizontal="12dp"
                android:textColor="#1E293B"
                android:textColorHint="#94A3B8"
                android:textSize="14sp" />

            <!-- Tuổi -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tuổi"
                android:textColor="#1A237E"
                android:textSize="14sp"
                android:textStyle="bold"
                android:drawableLeft="@drawable/ic_cake"
                android:drawablePadding="10dp"
                android:gravity="center_vertical" />
            <EditText
                android:id="@+id/etAge"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input_rect"
                android:hint="Nhập tuổi"
                android:inputType="number"
                android:paddingHorizontal="12dp"
                android:textColor="#1E293B"
                android:textColorHint="#94A3B8"
                android:textSize="14sp" />

            <!-- Email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textColor="#1A237E"
                android:textSize="14sp"
                android:textStyle="bold"
                android:drawableLeft="@drawable/ic_mail"
                android:drawablePadding="10dp"
                android:gravity="center_vertical" />
            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input_rect"
                android:hint="Nhập email"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="12dp"
                android:textColor="#1E293B"
                android:textColorHint="#94A3B8"
                android:textSize="14sp" />

            <!-- Lớp / Khoa -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lớp / Khoa"
                android:textColor="#1A237E"
                android:textSize="14sp"
                android:textStyle="bold"
                android:drawableLeft="@drawable/ic_school"
                android:drawablePadding="10dp"
                android:gravity="center_vertical" />
            <Spinner
                android:id="@+id/spClass"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input_rect"
                android:paddingHorizontal="12dp"
                android:spinnerMode="dropdown" />

            <!-- Địa chỉ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Địa chỉ"
                android:textColor="#1A237E"
                android:textSize="14sp"
                android:textStyle="bold"
                android:drawableLeft="@drawable/ic_home"
                android:drawablePadding="10dp"
                android:gravity="center_vertical" />
            <EditText
                android:id="@+id/etAddress"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input_rect"
                android:hint="Nhập địa chỉ"
                android:inputType="text"
                android:paddingHorizontal="12dp"
                android:textColor="#1E293B"
                android:textColorHint="#94A3B8"
                android:textSize="14sp" />

            <!-- Số điện thoại -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Số điện thoại"
                android:textColor="#1A237E"
                android:textSize="14sp"
                android:textStyle="bold"
                android:drawableLeft="@drawable/ic_phone"
                android:drawablePadding="10dp"
                android:gravity="center_vertical" />
            <EditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input_rect"
                android:hint="Nhập số điện thoại"
                android:inputType="phone"
                android:paddingHorizontal="12dp"
                android:textColor="#1E293B"
                android:textColorHint="#94A3B8"
                android:textSize="14sp" />

            <!-- Ngày sinh -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ngày sinh"
                android:textColor="#1A237E"
                android:textSize="14sp"
                android:textStyle="bold"
                android:drawableLeft="@drawable/ic_calendar"
                android:drawablePadding="10dp"
                android:gravity="center_vertical" />
            <RelativeLayout
                android:id="@+id/layoutBirthday"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input_rect"
                android:paddingHorizontal="12dp">
                <TextView
                    android:id="@+id/tvBirthday"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_toLeftOf="@+id/icCalendarClick"
                    android:text="Chọn ngày sinh"
                    android:textColor="#757575"
                    android:textSize="14sp"
                    android:gravity="center_vertical" />
                <ImageView
                    android:id="@+id/icCalendarClick"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentRight="true"
                    android:layout_centerInParent="true"
                    android:src="@drawable/ic_calendar"
                    app:tint="#757575" />
            </RelativeLayout>

            <!-- GPA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GPA (Điểm TB tích lũy)"
                android:textColor="#1A237E"
                android:textSize="14sp"
                android:textStyle="bold"
                android:drawableLeft="@drawable/ic_badge"
                android:drawablePadding="10dp"
                android:gravity="center_vertical" />
            <EditText
                android:id="@+id/etGpa"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input_rect"
                android:hint="Nhập GPA (vd: 3.5)"
                android:inputType="numberDecimal"
                android:paddingHorizontal="12dp"
                android:textColor="#1E293B"
                android:textColorHint="#94A3B8"
                android:textSize="14sp" />

            <!-- Giới tính -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Giới tính"
                    android:textColor="#1A237E"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:drawableLeft="@drawable/ic_gender"
                    android:drawablePadding="10dp" />
                <RadioGroup
                    android:id="@+id/rgGender"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginLeft="20dp">
                    <RadioButton
                        android:id="@+id/rbNam"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nam"
                        android:checked="true"
                        android:textSize="14sp"
                        android:layout_marginRight="16dp"/>
                    <RadioButton
                        android:id="@+id/rbNu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nữ"
                        android:textSize="14sp"/>
                </RadioGroup>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>